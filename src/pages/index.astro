---
import HomeLayout from '../layouts/HomeLayout.astro';
---

<HomeLayout title="Willkommen">
  <div class="relative">
    <div class="absolute top-4 right-4 flex items-center gap-1">
    <!-- Low-bandwidth (same preference as app Layout) -->
    <button
      type="button"
      id="low-bandwidth-toggle"
      data-toggle-low-bandwidth
      onclick="window.__cookbookToggleLowBandwidth(event)"
      class="btn-icon text-gray-700 dark:text-gray-300 hover:text-orange-500 dark:hover:text-orange-400"
      aria-label="Datenspar-Modus"
      aria-pressed="false"
      title="Datenspar-Modus: keine Rezeptbilder, keine Einbettungen"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M22 2L2 22" />
      </svg>
    </button>
    <!-- Theme Toggle Button -->
    <button id="theme-toggle" class="btn-icon text-gray-700 dark:text-gray-300 hover:text-orange-500 dark:hover:text-orange-400" aria-label="Toggle dark mode">
      <!-- Sun icon (visible in dark mode, to switch to light mode) -->
      <svg id="theme-toggle-light-icon" class="w-6 h-6 hidden dark:inline-block" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
        <path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" clip-rule="evenodd"></path>
      </svg>
      <!-- Moon icon (visible in light mode, to switch to dark mode) -->
      <svg id="theme-toggle-dark-icon" class="w-6 h-6 inline-block dark:hidden" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
        <path d="M17.293 13.293A8 8 0 0 1 6.707 2.707a8.001 8.001 0 1 0 10.586 10.586z" fill-rule="evenodd"></path>
      </svg>
    </button>
    <button
      type="button"
      id="ai-settings-open-btn"
      class="btn-icon text-gray-700 dark:text-gray-300 hover:text-indigo-500 dark:hover:text-indigo-400"
      aria-label="KI-Einstellungen öffnen"
      title="KI-Einstellungen"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317a1 1 0 011.35-.936l1.09.497a1 1 0 00.87 0l1.09-.497a1 1 0 011.35.936l.112 1.193a1 1 0 00.637.84l1.126.43a1 1 0 01.56 1.41l-.58 1.05a1 1 0 000 .966l.58 1.05a1 1 0 01-.56 1.41l-1.126.43a1 1 0 00-.637.84l-.112 1.193a1 1 0 01-1.35.936l-1.09-.497a1 1 0 00-.87 0l-1.09.497a1 1 0 01-1.35-.936l-.112-1.193a1 1 0 00-.637-.84l-1.126-.43a1 1 0 01-.56-1.41l.58-1.05a1 1 0 000-.966l-.58-1.05a1 1 0 01.56-1.41l1.126-.43a1 1 0 00.637-.84l.112-1.193z" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15a3 3 0 100-6 3 3 0 000 6z" />
      </svg>
    </button>
    </div>

    <div class="container mx-auto px-4 py-16 text-center">
      <!-- Large Logo -->
      <div class="mb-8 flex justify-center">
        <img src="/icons/icon_alpha_128.svg" alt="Kochbuch Logo" class="w-32 h-32 mx-auto" />
      </div>
      
      <!-- Project Name -->
      <h1 class="text-6xl font-bold text-gray-900 dark:text-white mb-8">Kochbuch</h1>
      
      <!-- Welcome Message -->
      <h2 class="text-4xl font-bold text-center mb-12 dark:text-white">Willkommen in deinem digitalen Kochbuch</h2>
      
      <!-- Navigation Cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <!-- Rezepte Card -->
        <a href="/rezepte" class="group">
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg p-8 transition-all duration-300 hover:shadow-xl hover:-translate-y-1 dark:shadow-gray-900">
            <div class="text-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 mx-auto mb-4 text-orange-500 dark:text-orange-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
              </svg>
              <h2 class="text-2xl font-semibold mb-4 dark:text-white">Rezepte</h2>
              <p class="text-gray-600 dark:text-gray-300">Entdecke und verwalte deine Lieblingsrezepte</p>
            </div>
          </div>
        </a>

        <!-- Einkaufslisten Card -->
        <a href="/einkaufslisten" class="group">
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow-lg p-8 transition-all duration-300 hover:shadow-xl hover:-translate-y-1 dark:shadow-gray-900">
            <div class="text-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 mx-auto mb-4 text-green-500 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
              </svg>
              <h2 class="text-2xl font-semibold mb-4 dark:text-white">Einkaufslisten</h2>
              <p class="text-gray-600 dark:text-gray-300">Plane und organisiere deine Einkäufe</p>
            </div>
          </div>
        </a>
      </div>
    </div>
  </div>

  <div
    id="ai-settings-modal"
    class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4"
    aria-modal="true"
    aria-labelledby="ai-settings-title"
  >
    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-2xl w-full max-w-lg border border-gray-200 dark:border-gray-700">
      <div class="flex items-center justify-between px-4 py-3 border-b border-gray-200 dark:border-gray-700">
        <h2 id="ai-settings-title" class="text-lg font-semibold text-gray-900 dark:text-white">KI-Einstellungen</h2>
        <button
          type="button"
          id="ai-settings-close-btn"
          class="p-2 text-gray-500 hover:text-gray-700 dark:hover:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition-colors"
          aria-label="Schließen"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <div class="p-4 space-y-4">
        <div>
          <label for="ai-provider-select" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Service</label>
          <select id="ai-provider-select" class="w-full px-3 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100">
            <option value="ollama">Ollama (lokal)</option>
            <option value="openrouter">OpenRouter</option>
          </select>
        </div>
        <div id="ai-openrouter-key-wrap" class="hidden">
          <label for="ai-openrouter-key" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">OpenRouter API-Key</label>
          <input
            id="ai-openrouter-key"
            type="password"
            placeholder="sk-or-v1-..."
            class="w-full px-3 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100"
          />
          <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">Wird nur lokal in deinem Browser gespeichert.</p>
        </div>
        <div>
          <div class="flex items-center justify-between mb-1">
            <label for="ai-model-select" class="block text-sm font-medium text-gray-700 dark:text-gray-300">Modell</label>
            <button type="button" id="ai-model-refresh-btn" class="text-xs text-indigo-600 dark:text-indigo-400 hover:underline">Aktualisieren</button>
          </div>
          <select id="ai-model-select" class="w-full px-3 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100"></select>
          <p id="ai-model-status" class="mt-1 text-xs text-gray-500 dark:text-gray-400"></p>
        </div>
      </div>
      <div class="flex justify-end gap-2 px-4 py-3 border-t border-gray-200 dark:border-gray-700">
        <button type="button" id="ai-settings-cancel-btn" class="px-4 py-2 rounded-lg border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300">Abbrechen</button>
        <button type="button" id="ai-settings-save-btn" class="px-4 py-2 rounded-lg bg-indigo-600 hover:bg-indigo-700 text-white font-medium">Speichern</button>
      </div>
    </div>
  </div>
</HomeLayout>

<script>
  // @ts-nocheck
  (function () {

    const STORAGE_KEY = 'cookbook.ai.settings';
    const defaultSettings = { provider: 'ollama', model: '', openRouterApiKey: '' };

    const openBtn = document.getElementById('ai-settings-open-btn');
    const modal = document.getElementById('ai-settings-modal');
    const closeBtn = document.getElementById('ai-settings-close-btn');
    const cancelBtn = document.getElementById('ai-settings-cancel-btn');
    const saveBtn = document.getElementById('ai-settings-save-btn');
    const providerSelect = document.getElementById('ai-provider-select');
    const modelSelect = document.getElementById('ai-model-select');
    const refreshBtn = document.getElementById('ai-model-refresh-btn');
    const keyWrap = document.getElementById('ai-openrouter-key-wrap');
    const keyInput = document.getElementById('ai-openrouter-key');
    const modelStatus = document.getElementById('ai-model-status');

    function loadSettings() {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) return { ...defaultSettings };
        return { ...defaultSettings, ...JSON.parse(raw) };
      } catch {
        return { ...defaultSettings };
      }
    }

    function saveSettings(settings) {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(settings));
      document.dispatchEvent(new CustomEvent('ai-settings-updated', { detail: settings }));
    }

    async function loadModels(provider, apiKey, selectedModel) {
      if (!modelSelect || !modelStatus) return;
      modelSelect.innerHTML = '<option value="">Lade Modelle…</option>';
      modelSelect.disabled = true;
      modelStatus.textContent = '';
      try {
        const headers = {};
        if (provider === 'openrouter' && apiKey) headers['x-openrouter-api-key'] = apiKey;
        const res = await fetch(`/api/ai/models?provider=${encodeURIComponent(provider)}`, { headers });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(data.error || 'Modelle konnten nicht geladen werden');
        const models = Array.isArray(data.models) ? data.models : [];
        modelSelect.innerHTML = '';
        if (models.length === 0) {
          modelSelect.innerHTML = '<option value="">Keine Modelle gefunden</option>';
          modelSelect.disabled = true;
          modelStatus.textContent = 'Keine Modelle verfügbar.';
          return;
        }
        models.forEach((model) => {
          const opt = document.createElement('option');
          opt.value = model;
          opt.textContent = model;
          modelSelect.appendChild(opt);
        });
        const target = selectedModel && models.includes(selectedModel) ? selectedModel : models[0];
        modelSelect.value = target;
        modelSelect.disabled = false;
        modelStatus.textContent = `${models.length} Modelle gefunden.`;
      } catch (e) {
        modelSelect.innerHTML = '<option value="">Fehler beim Laden</option>';
        modelSelect.disabled = true;
        modelStatus.textContent = e instanceof Error ? e.message : 'Fehler beim Laden';
      }
    }

    function toggleOpenRouterKey(provider) {
      if (!keyWrap) return;
      keyWrap.classList.toggle('hidden', provider !== 'openrouter');
    }

    async function openModal() {
      if (!modal || !providerSelect || !keyInput) return;
      const settings = loadSettings();
      providerSelect.value = settings.provider;
      keyInput.value = settings.openRouterApiKey || '';
      toggleOpenRouterKey(settings.provider);
      await loadModels(settings.provider, settings.openRouterApiKey, settings.model);
      modal.classList.remove('hidden');
      modal.classList.add('flex');
    }

    function closeModal() {
      if (!modal) return;
      modal.classList.add('hidden');
      modal.classList.remove('flex');
    }

    providerSelect && providerSelect.addEventListener('change', async () => {
      const provider = providerSelect.value === 'openrouter' ? 'openrouter' : 'ollama';
      const apiKey = keyInput ? keyInput.value.trim() : '';
      toggleOpenRouterKey(provider);
      await loadModels(provider, apiKey, '');
    });

    refreshBtn && refreshBtn.addEventListener('click', async () => {
      if (!providerSelect || !keyInput || !modelSelect) return;
      await loadModels(providerSelect.value, keyInput.value.trim(), modelSelect.value);
    });

    saveBtn && saveBtn.addEventListener('click', () => {
      if (!providerSelect || !keyInput || !modelSelect) return;
      const settings = {
        provider: providerSelect.value === 'openrouter' ? 'openrouter' : 'ollama',
        model: modelSelect.value || '',
        openRouterApiKey: keyInput.value.trim(),
      };
      saveSettings(settings);
      closeModal();
    });

    openBtn && openBtn.addEventListener('click', openModal);
    closeBtn && closeBtn.addEventListener('click', closeModal);
    cancelBtn && cancelBtn.addEventListener('click', closeModal);
    modal && modal.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });
  })();
</script>
