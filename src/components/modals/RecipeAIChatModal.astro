---
declare global {
  interface Window {
    openRecipeAIChatModal?: () => void;
  }
}

export interface ReferencedRecipe {
  id: string;
  title: string;
  imageUrl?: string;
}

interface Props {
  /** Recipes used as context for this chat. First one is the primary (recipeId for API). */
  referencedRecipes: ReferencedRecipe[];
}

const { referencedRecipes } = Astro.props;
const recipeId = referencedRecipes[0]?.id ?? '';
const recipeTitle = referencedRecipes[0]?.title ?? 'Rezept';
---

<div
  id="recipe-ai-chat-modal"
  class="hidden fixed inset-0 z-[90] flex items-stretch md:items-center justify-center p-0 md:p-4"
  style="z-index: 1000;"
  aria-modal="true"
  aria-labelledby="recipe-ai-chat-title"
>
  <div class="recipe-ai-chat-overlay absolute inset-0 bg-black/50"></div>
  <div class="recipe-ai-chat-panel bg-white dark:bg-gray-800 rounded-none md:rounded-xl shadow-2xl w-screen h-screen md:w-full md:max-w-2xl md:h-[80vh] flex flex-col border-0 md:border border-gray-200 dark:border-gray-700">
    <!-- Header -->
    <div class="px-4 py-3 border-b border-gray-200 dark:border-gray-700 flex-shrink-0">
      <div class="flex items-center justify-between gap-3">
        <h2 id="recipe-ai-chat-title" class="text-lg font-semibold text-gray-900 dark:text-white flex items-center gap-2 min-w-0">
          <span class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-indigo-100 dark:bg-indigo-900/40 text-indigo-600 dark:text-indigo-400">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
            </svg>
          </span>
          <span id="recipe-ai-chat-title-text" class="truncate">KI-Chat: {recipeTitle}</span>
        </h2>
        <div class="flex items-center gap-2 flex-shrink-0">
          <button
            type="button"
            id="recipe-ai-chat-delete-btn"
            class="px-3 py-1.5 text-sm font-medium text-gray-600 dark:text-gray-400 hover:text-red-600 dark:hover:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-lg transition-colors"
            title="Chat-Verlauf löschen"
          >
            Chat löschen
          </button>
          <button
            type="button"
            id="recipe-ai-chat-close-btn"
            class="p-2 text-gray-500 hover:text-gray-700 dark:hover:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg transition-colors"
            aria-label="Schließen"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
      </div>
      <div class="mt-3 flex flex-col md:flex-row md:items-center gap-2">
        <div class="flex items-center gap-2">
          <label for="recipe-ai-chat-provider-select" class="text-xs font-medium text-gray-500 dark:text-gray-400">Provider</label>
          <select
            id="recipe-ai-chat-provider-select"
            class="px-2.5 py-1.5 text-xs rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100"
          >
            <option value="ollama">Ollama</option>
            <option value="openrouter">OpenRouter</option>
          </select>
        </div>
        <div class="flex items-center gap-2 min-w-0 flex-1">
          <label for="recipe-ai-chat-model-select" class="text-xs font-medium text-gray-500 dark:text-gray-400">Modell</label>
          <select
            id="recipe-ai-chat-model-select"
            class="min-w-0 flex-1 px-2.5 py-1.5 text-xs rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100"
          ></select>
          <button
            type="button"
            id="recipe-ai-chat-model-refresh-btn"
            class="px-2 py-1.5 text-xs rounded-md border border-gray-300 dark:border-gray-600 text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700"
          >
            Neu laden
          </button>
        </div>
      </div>
      <p id="recipe-ai-chat-model-status" class="mt-1 text-[11px] text-gray-500 dark:text-gray-400"></p>
      <p id="recipe-ai-chat-cache-hint" class="mt-1 text-[11px] text-indigo-600 dark:text-indigo-300"></p>
      <p id="recipe-ai-chat-cache-impact" class="mt-1 text-[11px] text-amber-600 dark:text-amber-300"></p>
      <div class="mt-3 flex items-center gap-2">
        <div id="recipe-ai-chat-tabs" class="flex-1 min-w-0 flex gap-1 overflow-x-auto pb-1">
          <!-- chat tabs rendered by script -->
        </div>
        <button
          type="button"
          id="recipe-ai-chat-new-tab-btn"
          class="flex-shrink-0 px-2 py-1 text-xs rounded-md border border-gray-300 dark:border-gray-600 text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700"
        >
          Neuer Chat
        </button>
      </div>
    </div>

    <!-- Messages -->
    <div id="recipe-ai-chat-messages" class="flex-1 overflow-y-auto p-4 space-y-4 min-h-0 bg-gray-50 dark:bg-gray-900/30">
      <div id="recipe-ai-chat-placeholder" class="text-center py-8 text-gray-500 dark:text-gray-400 text-sm">
        Stelle Fragen zum Rezept oder bitte die KI, eine Variante vorzuschlagen. Der Verlauf wird gespeichert, bis du „Chat löschen“ wählst.
      </div>
    </div>

    <!-- Referenced recipe(s) – thin bar above input (populated by script) -->
    <div class="px-4 py-2 border-t border-gray-200 dark:border-gray-700 flex-shrink-0 bg-white dark:bg-gray-800" id="recipe-ai-chat-referenced-wrap">
      <p class="text-xs font-medium text-gray-500 dark:text-gray-400 mb-2">Referenzierte Rezepte</p>
      <div class="flex gap-2 overflow-x-auto pb-1 flex-wrap items-center" id="recipe-ai-chat-referenced-list">
        <!-- chips rendered by script -->
      </div>
    </div>

    <!-- Input row: plus button + input + send -->
  <div class="recipe-ai-chat-input-row p-4 border-t border-gray-200 dark:border-gray-700 flex-shrink-0">
      <div class="flex gap-2 items-center">
        <button
          type="button"
          id="recipe-ai-chat-add-ref-btn"
          class="flex-shrink-0 p-2.5 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-600 transition-colors"
          title="Weitere Rezepte im Chat referenzieren"
          aria-label="Rezepte hinzufügen"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
          </svg>
        </button>
        <input
          type="text"
          id="recipe-ai-chat-input"
          placeholder="Nachricht eingeben…"
          class="flex-1 min-w-0 px-4 py-2.5 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100 placeholder-gray-500 dark:placeholder-gray-400 focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
          autocomplete="off"
        />
        <button
          type="button"
          id="recipe-ai-chat-send-btn"
          class="flex-shrink-0 px-4 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg font-medium transition-colors flex items-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed"
          title="Senden"
        >
          <svg class="w-4 h-4 recipe-ai-chat-send-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
          </svg>
          <span class="recipe-ai-chat-send-label">Senden</span>
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Picker modal: add recipes to chat context -->
<div
  id="recipe-ai-chat-picker-modal"
  class="hidden fixed inset-0 z-[95] flex items-center justify-center p-4"
  style="z-index: 1010;"
  aria-modal="true"
  aria-label="Rezepte zum Chat hinzufügen"
>
  <div class="recipe-ai-chat-overlay absolute inset-0 bg-black/50"></div>
  <div class="bg-white dark:bg-gray-800 rounded-xl shadow-2xl w-full max-w-lg max-h-[80vh] flex flex-col border border-gray-200 dark:border-gray-700">
    <div class="flex items-center justify-between px-4 py-3 border-b border-gray-200 dark:border-gray-700">
      <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Rezepte referenzieren</h3>
      <button type="button" id="recipe-ai-chat-picker-close" class="p-2 text-gray-500 hover:text-gray-700 dark:hover:text-gray-300 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700" aria-label="Schließen">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <p class="px-4 py-2 text-sm text-gray-600 dark:text-gray-400">Wähle Rezepte, die die KI zusätzlich berücksichtigen soll.</p>
    <div class="flex-1 overflow-y-auto px-4 pb-2">
      <div id="recipe-ai-chat-picker-list" class="space-y-1">
        <!-- loaded by script -->
      </div>
    </div>
    <div class="flex justify-end gap-2 px-4 py-3 border-t border-gray-200 dark:border-gray-700">
      <button type="button" id="recipe-ai-chat-picker-cancel" class="px-4 py-2 text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-700 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-600">Abbrechen</button>
      <button type="button" id="recipe-ai-chat-picker-add" class="px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg font-medium">Hinzufügen</button>
    </div>
  </div>
</div>

<!-- Markdown parser for AI chat (browser global window.marked) -->
<script src="https://cdn.jsdelivr.net/npm/marked@15.0.0/marked.min.js" crossorigin="anonymous"></script>

<script define:vars={{ recipeId, recipeTitle, initialReferencedRecipes: referencedRecipes }}>
  (function () {
    const modal = document.getElementById('recipe-ai-chat-modal');
    const messagesContainer = document.getElementById('recipe-ai-chat-messages');
    const placeholder = document.getElementById('recipe-ai-chat-placeholder');
    const input = document.getElementById('recipe-ai-chat-input');
    const sendBtn = document.getElementById('recipe-ai-chat-send-btn');
    const closeBtn = document.getElementById('recipe-ai-chat-close-btn');
    const deleteBtn = document.getElementById('recipe-ai-chat-delete-btn');
    const addRefBtn = document.getElementById('recipe-ai-chat-add-ref-btn');
    const referencedListEl = document.getElementById('recipe-ai-chat-referenced-list');
    const referencedWrapEl = document.getElementById('recipe-ai-chat-referenced-wrap');
    const chatTitleText = document.getElementById('recipe-ai-chat-title-text');
    const pickerModal = document.getElementById('recipe-ai-chat-picker-modal');
    const pickerList = document.getElementById('recipe-ai-chat-picker-list');
    const pickerClose = document.getElementById('recipe-ai-chat-picker-close');
    const pickerCancel = document.getElementById('recipe-ai-chat-picker-cancel');
    const pickerAdd = document.getElementById('recipe-ai-chat-picker-add');
    const aiProviderSelect = document.getElementById('recipe-ai-chat-provider-select');
    const aiModelSelect = document.getElementById('recipe-ai-chat-model-select');
    const aiModelRefreshBtn = document.getElementById('recipe-ai-chat-model-refresh-btn');
    const aiModelStatus = document.getElementById('recipe-ai-chat-model-status');
    const aiCacheHint = document.getElementById('recipe-ai-chat-cache-hint');
    const aiCacheImpact = document.getElementById('recipe-ai-chat-cache-impact');
    const chatTabsEl = document.getElementById('recipe-ai-chat-tabs');
    const newChatTabBtn = document.getElementById('recipe-ai-chat-new-tab-btn');

    const RECIPE_VARIANT_TOOL_REGEX = /\[RECIPE_VARIANT(?::([a-zA-Z0-9-_]+))?\]/g;
    const ALL_RECIPES_CONTEXT_ID = '__all_recipes__';
    const RECIPE_REF_TOOL_REGEX = /\[RECIPE_REF:([a-zA-Z0-9-_]+)\]/g;
    const SHOPPING_LIST_TOOL_REGEX = /\[SHOPPING_LIST_RECIPES:([a-zA-Z0-9\-_,@:\s]+)\]/g;
    const RECIPE_EDIT_TOOL_REGEX = /\[RECIPE_EDIT:([a-zA-Z0-9-_]+)(?:\|regions=([a-zA-Z0-9._,\s-]+))?\]/g;
    let messages = [];
    let isGenerating = false;
    let currentAbortController = null;
    let referencedRecipesList = Array.isArray(initialReferencedRecipes)
      ? initialReferencedRecipes.map((r) => ({ id: r.id, title: r.title || '', imageUrl: r.imageUrl }))
      : [];
    let allRecipesForPicker = [];
    const AI_SETTINGS_KEY = 'cookbook.ai.settings';
    const CHAT_MODEL_MEMORY_KEY = 'cookbook.ai.chat.modelMemory';
    const CHAT_TABS_STORAGE_PREFIX = 'cookbook.ai.chat.tabs.v1';
    const CHAT_TAB_RETENTION_MS = 30 * 24 * 60 * 60 * 1000;
    let activeChatProvider = 'ollama';
    let activeChatModel = '';
    let chatTabs = [];
    let activeChatTabId = '';
    const titleGenerationInFlight = new Set();
    const recipeTitleCache = new Map();
    const DEBUG_ENABLED = new URLSearchParams(window.location.search).get('debug') === '1';
    let allRecipesCache = null;
    const CHAT_VH_VAR = '--recipe-ai-chat-vh';
    const modelMetaById = new Map();

    function getActiveTab() {
      return chatTabs.find((t) => t.id === activeChatTabId) || null;
    }

    function isTabModelLocked(tab) {
      return Boolean(tab && Array.isArray(tab.messages) && tab.messages.length > 0);
    }

    function setCacheImpact(message) {
      if (!aiCacheImpact) return;
      aiCacheImpact.textContent = message || '';
    }

    function getModelCacheMeta(modelId) {
      const meta = modelMetaById.get(modelId);
      if (meta && typeof meta === 'object') return meta;
      return { cacheSupported: false, cacheMode: 'unknown', cacheNote: 'Keine Cache-Infos verfügbar.' };
    }

    function updateCacheHint() {
      if (!aiCacheHint) return;
      const selected = aiModelSelect && aiModelSelect.value ? aiModelSelect.value : activeChatModel;
      const meta = getModelCacheMeta(selected);
      const lockSuffix = (() => {
        const tab = getActiveTab();
        if (isTabModelLocked(tab)) return ' Modellwechsel in diesem Chat deaktiviert.';
        return '';
      })();
      if (meta.cacheSupported) {
        const modeText = meta.cacheMode === 'explicit' ? 'Explizites Cache-Control' : 'Automatisches Caching';
        aiCacheHint.textContent = `Cache: ${modeText}. ${meta.cacheNote}${lockSuffix}`;
      } else if (meta.cacheMode === 'none') {
        aiCacheHint.textContent = `Cache: Nicht verfügbar. ${meta.cacheNote}${lockSuffix}`;
      } else {
        aiCacheHint.textContent = `Cache: Unbekannt. ${meta.cacheNote}${lockSuffix}`;
      }
    }

    function withDebugParam(targetUrl) {
      if (!DEBUG_ENABLED) return targetUrl;
      try {
        const url = new URL(targetUrl, window.location.origin);
        url.searchParams.set('debug', '1');
        return `${url.pathname}${url.search}${url.hash}`;
      } catch {
        return targetUrl;
      }
    }

    function updateChatViewportHeightVar() {
      const vv = window.visualViewport;
      const height = vv && vv.height ? vv.height : window.innerHeight;
      document.documentElement.style.setProperty(CHAT_VH_VAR, `${Math.round(height)}px`);
    }

    function makeTabId() {
      if (window.crypto && typeof window.crypto.randomUUID === 'function') return window.crypto.randomUUID();
      return `${Date.now()}-${Math.random().toString(16).slice(2)}`;
    }

    function nowIso() {
      return new Date().toISOString();
    }

    function getChatTabsStorageKey() {
      return `${CHAT_TABS_STORAGE_PREFIX}:${getPrimaryRecipeId()}`;
    }

    function normalizeChatMessages(input) {
      if (!Array.isArray(input)) return [];
      return input
        .filter((m) => m && typeof m === 'object')
        .map((m) => {
          const role = m.role === 'user' || m.role === 'assistant' ? m.role : null;
          const content = typeof m.content === 'string' ? m.content : null;
          if (!role || content == null) return null;
          return { role, content };
        })
        .filter(Boolean);
    }

    function makeDefaultTab() {
      const now = nowIso();
      return {
        id: makeTabId(),
        title: 'Neuer Chat',
        aiTitleGenerated: false,
        messages: [],
        provider: activeChatProvider || 'ollama',
        model: activeChatModel || '',
        createdAt: now,
        updatedAt: now,
        lastViewedAt: now,
      };
    }

    function deriveTabTitle(messagesList) {
      const firstUser = Array.isArray(messagesList)
        ? messagesList.find((m) => m.role === 'user' && typeof m.content === 'string' && m.content.trim())
        : null;
      if (!firstUser) return 'Neuer Chat';
      const text = firstUser.content.trim().replace(/\s+/g, ' ');
      return text.length > 34 ? `${text.slice(0, 34)}...` : text;
    }

    function persistChatTabs() {
      try {
        localStorage.setItem(getChatTabsStorageKey(), JSON.stringify(chatTabs));
      } catch (e) {
        console.warn('Persist chat tabs failed', e);
      }
    }

    function touchActiveTab() {
      const idx = chatTabs.findIndex((t) => t.id === activeChatTabId);
      if (idx < 0) return;
      const tab = chatTabs[idx];
      tab.messages = normalizeChatMessages(messages);
      if (!tab.provider) tab.provider = activeChatProvider || 'ollama';
      if (!tab.model) tab.model = activeChatModel || '';
      if (!tab.title || tab.title === 'Neuer Chat') {
        tab.title = deriveTabTitle(tab.messages);
      }
      tab.updatedAt = nowIso();
      tab.lastViewedAt = nowIso();
      chatTabs[idx] = tab;
      persistChatTabs();
      renderChatTabs();
      void maybeGenerateAiTabTitle(tab.id);
    }

    async function maybeGenerateAiTabTitle(tabId) {
      const tab = chatTabs.find((t) => t.id === tabId);
      if (!tab) return;
      if (titleGenerationInFlight.has(tabId)) return;
      if (tab.aiTitleGenerated === true) return;
      const heuristicTitle = deriveTabTitle(tab.messages);
      if (tab.title && tab.title !== 'Neuer Chat' && tab.title !== heuristicTitle) return;
      const hasUser = Array.isArray(tab.messages) && tab.messages.some((m) => m.role === 'user' && m.content && m.content.trim());
      if (!hasUser) return;
      titleGenerationInFlight.add(tabId);
      try {
        const res = await fetch('/api/ai/chat-title', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            messages: tab.messages.slice(-8),
            ...getAISettings(),
            provider: activeChatProvider,
            model: activeChatModel,
          }),
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok || !data?.title) return;
        const freshIdx = chatTabs.findIndex((t) => t.id === tabId);
        if (freshIdx < 0) return;
        const fresh = chatTabs[freshIdx];
        const freshHeuristic = deriveTabTitle(fresh.messages);
        if (fresh.aiTitleGenerated === true) return;
        if (fresh.title && fresh.title !== 'Neuer Chat' && fresh.title !== freshHeuristic) return;
        fresh.title = String(data.title).trim().slice(0, 48) || fresh.title || 'Neuer Chat';
        fresh.aiTitleGenerated = true;
        fresh.updatedAt = nowIso();
        chatTabs[freshIdx] = fresh;
        persistChatTabs();
        renderChatTabs();
      } catch (e) {
        console.warn('AI title generation failed', e);
      } finally {
        titleGenerationInFlight.delete(tabId);
      }
    }

    function selectChatTab(tabId) {
      const tab = chatTabs.find((t) => t.id === tabId);
      if (!tab) return;
      activeChatTabId = tab.id;
      tab.lastViewedAt = nowIso();
      if (!tab.provider) tab.provider = activeChatProvider || 'ollama';
      if (!tab.model) tab.model = activeChatModel || '';
      activeChatProvider = tab.provider;
      activeChatModel = tab.model || '';
      messages = normalizeChatMessages(tab.messages);
      persistChatTabs();
      renderChatTabs();
      renderMessages();
      syncHeaderModelChooser();
    }

    function removeChatTab(tabId) {
      if (chatTabs.length <= 1) return;
      const filtered = chatTabs.filter((t) => t.id !== tabId);
      if (filtered.length === 0) return;
      chatTabs = filtered;
      if (!chatTabs.some((t) => t.id === activeChatTabId)) {
        activeChatTabId = chatTabs[0].id;
      }
      persistChatTabs();
      selectChatTab(activeChatTabId);
    }

    function createChatTab() {
      const previousProvider = activeChatProvider;
      const previousModel = activeChatModel;
      const tab = makeDefaultTab();
      tab.provider = previousProvider || tab.provider || 'ollama';
      tab.model = previousModel || tab.model || '';
      chatTabs.unshift(tab);
      activeChatTabId = tab.id;
      activeChatProvider = tab.provider;
      activeChatModel = tab.model;
      messages = [];
      setCacheImpact('Neuer Chat gestartet: Cache wird neu aufgebaut.');
      persistChatTabs();
      renderChatTabs();
      renderMessages();
      void syncHeaderModelChooser();
      if (input) input.focus();
    }

    function renderChatTabs() {
      if (!chatTabsEl) return;
      chatTabsEl.innerHTML = '';
      chatTabs.forEach((tab) => {
        const isActive = tab.id === activeChatTabId;
        const item = document.createElement('div');
        item.className = `flex items-center gap-1 rounded-md border px-2 py-1 text-xs ${isActive ? 'border-indigo-300 bg-indigo-50 text-indigo-700 dark:border-indigo-700 dark:bg-indigo-900/30 dark:text-indigo-300' : 'border-gray-300 text-gray-600 dark:border-gray-600 dark:text-gray-300'}`;
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'truncate max-w-[150px]';
        btn.textContent = `${tab.title || 'Neuer Chat'}${isTabModelLocked(tab) ? ' 🔒' : ''}`;
        btn.addEventListener('click', () => selectChatTab(tab.id));
        item.appendChild(btn);
        if (chatTabs.length > 1) {
          const del = document.createElement('button');
          del.type = 'button';
          del.className = 'text-gray-400 hover:text-red-500';
          del.setAttribute('aria-label', 'Tab löschen');
          del.innerHTML = '&times;';
          del.addEventListener('click', (e) => {
            e.stopPropagation();
            removeChatTab(tab.id);
          });
          item.appendChild(del);
        }
        chatTabsEl.appendChild(item);
      });
    }

    function initChatTabs() {
      const now = Date.now();
      let loaded = [];
      try {
        const raw = localStorage.getItem(getChatTabsStorageKey());
        const parsed = raw ? JSON.parse(raw) : [];
        loaded = Array.isArray(parsed) ? parsed : [];
      } catch {
        loaded = [];
      }
      chatTabs = loaded
        .filter((tab) => tab && typeof tab === 'object' && typeof tab.id === 'string')
        .map((tab) => ({
          id: tab.id,
          title: typeof tab.title === 'string' && tab.title.trim() ? tab.title.trim() : 'Neuer Chat',
          aiTitleGenerated: tab.aiTitleGenerated === true,
          messages: normalizeChatMessages(tab.messages),
          provider: tab.provider === 'openrouter' ? 'openrouter' : 'ollama',
          model: typeof tab.model === 'string' ? tab.model : '',
          createdAt: typeof tab.createdAt === 'string' ? tab.createdAt : nowIso(),
          updatedAt: typeof tab.updatedAt === 'string' ? tab.updatedAt : nowIso(),
          lastViewedAt: typeof tab.lastViewedAt === 'string' ? tab.lastViewedAt : nowIso(),
        }))
        .filter((tab) => {
          const ts = Date.parse(tab.lastViewedAt);
          return Number.isFinite(ts) ? now - ts <= CHAT_TAB_RETENTION_MS : true;
        });
      if (chatTabs.length === 0) {
        chatTabs = [makeDefaultTab()];
      }
      activeChatTabId = chatTabs[0].id;
      activeChatProvider = chatTabs[0].provider || activeChatProvider;
      activeChatModel = chatTabs[0].model || activeChatModel;
      messages = normalizeChatMessages(chatTabs[0].messages);
      persistChatTabs();
      renderChatTabs();
      renderMessages();
    }

    function getAISettings() {
      const defaults = { provider: 'ollama', model: '', openRouterApiKey: '' };
      try {
        const raw = localStorage.getItem(AI_SETTINGS_KEY);
        if (!raw) return defaults;
        return { ...defaults, ...JSON.parse(raw) };
      } catch {
        return defaults;
      }
    }

    function getDefaultAIConfig() {
      const settings = getAISettings();
      return {
        provider: settings.provider === 'openrouter' ? 'openrouter' : 'ollama',
        model: typeof settings.model === 'string' ? settings.model : '',
        openRouterApiKey: typeof settings.openRouterApiKey === 'string' ? settings.openRouterApiKey : '',
      };
    }

    function getChatModelMemory() {
      try {
        const raw = localStorage.getItem(CHAT_MODEL_MEMORY_KEY);
        if (!raw) return {};
        const parsed = JSON.parse(raw);
        return parsed && typeof parsed === 'object' ? parsed : {};
      } catch {
        return {};
      }
    }

    function setChatModelMemory(memory) {
      localStorage.setItem(CHAT_MODEL_MEMORY_KEY, JSON.stringify(memory || {}));
    }

    async function loadModelsForHeader(provider, apiKey, selectedModel) {
      if (!aiModelSelect || !aiModelStatus) return '';
      aiModelSelect.innerHTML = '<option value="">Lade Modelle...</option>';
      aiModelSelect.disabled = true;
      aiModelStatus.textContent = '';
      try {
        const headers = {};
        if (provider === 'openrouter' && apiKey) headers['x-openrouter-api-key'] = apiKey;
        const res = await fetch(`/api/ai/models?provider=${encodeURIComponent(provider)}`, { headers });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(data.error || 'Modelle konnten nicht geladen werden');
        const models = Array.isArray(data.models) ? data.models : [];
        const modelDetails = Array.isArray(data.modelDetails) ? data.modelDetails : [];
        modelMetaById.clear();
        modelDetails.forEach((detail) => {
          if (!detail || typeof detail !== 'object' || typeof detail.id !== 'string') return;
          modelMetaById.set(detail.id, {
            cacheSupported: detail.cacheSupported === true,
            cacheMode: typeof detail.cacheMode === 'string' ? detail.cacheMode : 'unknown',
            cacheNote: typeof detail.cacheNote === 'string' ? detail.cacheNote : '',
          });
        });
        const openRouterAccess = data.openRouterAccess && typeof data.openRouterAccess === 'object'
          ? data.openRouterAccess
          : null;
        aiModelSelect.innerHTML = '';
        if (models.length === 0) {
          aiModelSelect.innerHTML = '<option value="">Keine Modelle gefunden</option>';
          aiModelSelect.disabled = true;
          aiModelStatus.textContent = 'Keine Modelle verfügbar.';
          return '';
        }
        models.forEach((model) => {
          const meta = getModelCacheMeta(model);
          const opt = document.createElement('option');
          opt.value = model;
          const marker = meta.cacheSupported
            ? (meta.cacheMode === 'explicit' ? ' [Cache*]' : ' [Cache]')
            : '';
          opt.textContent = `${model}${marker}`;
          aiModelSelect.appendChild(opt);
        });
        const target = selectedModel && models.includes(selectedModel) ? selectedModel : models[0];
        aiModelSelect.value = target;
        aiModelSelect.disabled = false;
        if (provider === 'openrouter' && openRouterAccess && openRouterAccess.freeOnly) {
          aiModelStatus.textContent = `${models.length} kostenlose OpenRouter-Modelle verfügbar.`;
        } else {
          aiModelStatus.textContent = `${models.length} Modelle verfügbar.`;
        }
        updateCacheHint();
        return target;
      } catch (e) {
        aiModelSelect.innerHTML = '<option value="">Fehler beim Laden</option>';
        aiModelSelect.disabled = true;
        aiModelStatus.textContent = e instanceof Error ? e.message : 'Fehler beim Laden';
        updateCacheHint();
        return '';
      }
    }

    async function syncHeaderModelChooser() {
      if (!aiProviderSelect || !aiModelSelect) return;
      const settings = getDefaultAIConfig();
      const activeTab = getActiveTab();
      const provider = activeTab?.provider || activeChatProvider || settings.provider;
      aiProviderSelect.value = provider;
      const preferredModel = activeTab?.model || activeChatModel || settings.model;
      const selectedModel = await loadModelsForHeader(provider, settings.openRouterApiKey, preferredModel);
      activeChatProvider = provider;
      activeChatModel = selectedModel || '';
      if (activeTab) {
        activeTab.provider = activeChatProvider;
        activeTab.model = activeChatModel;
      }
      const isLocked = isTabModelLocked(activeTab);
      aiProviderSelect.disabled = isLocked;
      aiModelSelect.disabled = isLocked || !selectedModel;
      if (aiModelRefreshBtn) aiModelRefreshBtn.disabled = isLocked;
      updateCacheHint();
    }

    function getPrimaryRecipeId() {
      return referencedRecipesList.length > 0 ? referencedRecipesList[0].id : recipeId;
    }

    function isAllRecipesContext() {
      return getPrimaryRecipeId() === ALL_RECIPES_CONTEXT_ID;
    }

    function updateChatTitle() {
      if (!chatTitleText) return;
      if (referencedRecipesList.length === 0) {
        chatTitleText.textContent = 'KI-Chat: ' + (recipeTitle || 'Rezept');
      } else if (referencedRecipesList.length === 1) {
        chatTitleText.textContent = 'KI-Chat: ' + referencedRecipesList[0].title;
      } else {
        chatTitleText.textContent = 'KI-Chat: Mehrere Rezepte';
      }
    }

    function renderReferencedBar() {
      if (!referencedListEl) return;
      referencedListEl.innerHTML = '';
      referencedRecipesList.forEach((r) => {
        if (r.id && r.title) recipeTitleCache.set(r.id, r.title);
        const chip = document.createElement('div');
        chip.className = 'flex items-center gap-1.5 min-w-0 flex-shrink-0 rounded-lg border border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-700 shadow-sm pr-1 py-1 pl-2 group';
        const link = document.createElement('a');
        link.href = '/rezept/' + r.id;
        link.target = '_blank';
        link.rel = 'noopener noreferrer';
        link.className = 'flex items-center gap-2 min-w-0 flex-1 hover:opacity-80';
        if (r.id === ALL_RECIPES_CONTEXT_ID) {
          link.removeAttribute('href');
          link.removeAttribute('target');
          link.removeAttribute('rel');
          link.className = 'flex items-center gap-2 min-w-0 flex-1 cursor-default';
        }
        if (r.imageUrl) {
          const img = document.createElement('img');
          img.src = r.imageUrl;
          img.alt = '';
          img.className = 'w-8 h-8 rounded object-cover flex-shrink-0';
          link.appendChild(img);
        } else {
          const span = document.createElement('span');
          span.className = 'w-8 h-8 rounded bg-gray-200 dark:bg-gray-700 flex-shrink-0 flex items-center justify-center text-gray-400 dark:text-gray-500';
          span.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>';
          link.appendChild(span);
        }
        const titleSpan = document.createElement('span');
        titleSpan.className = 'text-sm font-medium text-gray-900 dark:text-gray-100 truncate max-w-[120px]';
        titleSpan.textContent = r.title;
        link.appendChild(titleSpan);
        chip.appendChild(link);
        if (r.id !== ALL_RECIPES_CONTEXT_ID) {
          const removeBtn = document.createElement('button');
          removeBtn.type = 'button';
          removeBtn.className = 'p-1 rounded text-gray-400 hover:text-red-600 dark:hover:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20';
          removeBtn.setAttribute('aria-label', 'Referenz entfernen');
          removeBtn.innerHTML = '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>';
          removeBtn.addEventListener('click', (e) => {
            e.preventDefault();
            referencedRecipesList = referencedRecipesList.filter((x) => x.id !== r.id);
            renderReferencedBar();
            updateChatTitle();
          });
          chip.appendChild(removeBtn);
        }
        referencedListEl.appendChild(chip);
      });
      if (referencedWrapEl) referencedWrapEl.classList.toggle('hidden', referencedRecipesList.length === 0);
      updateChatTitle();
    }

    function openReferencePicker() {
      if (isAllRecipesContext()) return;
      if (!pickerModal || !pickerList) return;
      pickerModal.classList.remove('hidden');
      pickerModal.classList.add('flex');
      pickerList.innerHTML = '<p class="text-center py-4 text-gray-500 dark:text-gray-400">Lade Rezepte…</p>';
      fetch('/api/recipes')
        .then((res) => res.ok ? res.json() : [])
        .then((recipes) => {
          allRecipesForPicker = recipes;
          const refIds = new Set(referencedRecipesList.map((r) => r.id));
          const toShow = recipes.filter((rec) => !refIds.has(rec.id));
          if (toShow.length === 0) {
            pickerList.innerHTML = '<p class="text-center py-4 text-gray-500 dark:text-gray-400">Alle Rezepte sind bereits referenziert.</p>';
            return;
          }
          pickerList.innerHTML = toShow
            .map(
              (rec) => `
            <label class="flex items-center gap-3 p-3 rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 cursor-pointer">
              <input type="checkbox" class="recipe-ai-picker-cb w-4 h-4 rounded border-gray-300 text-indigo-600" data-recipe-id="${rec.id}" data-recipe-title="${(rec.title || '').replace(/"/g, '&quot;')}" data-recipe-image="${(rec.images?.[0]?.url || rec.imageUrl || '').replace(/"/g, '&quot;')}" />
              ${
                rec.images?.[0]?.url || rec.imageUrl
                  ? `<img src="${(rec.images?.[0]?.url || rec.imageUrl).replace(/"/g, '&quot;')}" alt="" class="w-8 h-8 rounded object-cover flex-shrink-0" />`
                  : '<span class="w-8 h-8 rounded bg-gray-200 dark:bg-gray-700 flex-shrink-0 flex items-center justify-center text-gray-400"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg></span>'
              }
              <span class="text-sm font-medium text-gray-900 dark:text-gray-100 truncate flex-1">${(rec.title || '').replace(/</g, '&lt;')}</span>
            </label>
          `
            )
            .join('');
          // checkboxes are in DOM; addSelectedFromPicker uses querySelectorAll
        })
        .catch(() => {
          pickerList.innerHTML = '<p class="text-center py-4 text-red-500">Fehler beim Laden.</p>';
        });
    }

    function closeReferencePicker() {
      if (pickerModal) {
        pickerModal.classList.add('hidden');
        pickerModal.classList.remove('flex');
      }
    }

    function addSelectedFromPicker() {
      const toAdd = [];
      const checked = pickerList.querySelectorAll('.recipe-ai-picker-cb:checked');
      checked.forEach((cb) => {
        const id = cb.getAttribute('data-recipe-id');
        const title = cb.getAttribute('data-recipe-title') || '';
        const image = cb.getAttribute('data-recipe-image') || '';
        if (id && !referencedRecipesList.some((r) => r.id === id)) toAdd.push({ id, title, imageUrl: image || undefined });
      });
      referencedRecipesList = referencedRecipesList.concat(toAdd);
      renderReferencedBar();
      closeReferencePicker();
    }

    addRefBtn && addRefBtn.addEventListener('click', openReferencePicker);
    pickerClose && pickerClose.addEventListener('click', closeReferencePicker);
    pickerCancel && pickerCancel.addEventListener('click', closeReferencePicker);
    pickerAdd && pickerAdd.addEventListener('click', addSelectedFromPicker);
    pickerModal && pickerModal.addEventListener('click', (e) => { if (e.target === pickerModal) closeReferencePicker(); });

    function regenerateMessage(messageIndex) {
      if (!Array.isArray(messages) || messageIndex == null) return;
      // Find the last user message before this assistant message
      let userText = '';
      let userIdx = -1;
      for (let i = messageIndex - 1; i >= 0; i--) {
        const m = messages[i];
        if (m && m.role === 'user' && typeof m.content === 'string') {
          userText = m.content;
          userIdx = i;
          break;
        }
      }
      if (!userText) return;
      const baseHistory = userIdx > 0 ? messages.slice(0, userIdx) : [];
      setCacheImpact('Antwort neu generieren: Der Chat-Verlauf ab dieser Stelle wird ersetzt (Cache neu aufgebaut).');
      sendMessage({ textOverride: userText, historyOverride: baseHistory, regenerate: true });
    }

    function getMarked() {
      try {
        // marked UMD attaches itself to window.marked
        // @ts-ignore
        return window.marked || null;
      } catch {
        return null;
      }
    }

    function extractVariantPayload(text) {
      if (!text || typeof text !== 'string') return { hasVariant: false, recipeId: '' };
      const regex = new RegExp(RECIPE_VARIANT_TOOL_REGEX);
      const match = regex.exec(text);
      if (!match) return { hasVariant: false, recipeId: '' };
      return { hasVariant: true, recipeId: match?.[1] || '' };
    }

    function stripVariantKeyword(text) {
      if (!text || typeof text !== 'string') return text || '';
      let result = text;
      result = result.replace(/^\s*\[RECIPE_VARIANT(?::[a-zA-Z0-9-_]+)?\]\s*\n?/gim, '');
      result = result.replace(/^\s*\*\*\[?RECIPE_VARIANT(?::[a-zA-Z0-9-_]+)?\]?\*\*\s*\n?/gim, '');
      return result.trim();
    }

    function splitThinkingContent(text) {
      if (!text || typeof text !== 'string') return { visible: '', thinking: '' };
      const thinkingParts = [];
      const visible = text
        .replace(/<think>([\s\S]*?)<\/think>/gi, (_m, inner) => {
          const value = (inner || '').trim();
          if (value) thinkingParts.push(value);
          return '';
        })
        .replace(/<thinking>([\s\S]*?)<\/thinking>/gi, (_m, inner) => {
          const value = (inner || '').trim();
          if (value) thinkingParts.push(value);
          return '';
        })
        .trim();
      return {
        visible,
        thinking: thinkingParts.join('\n\n').trim(),
      };
    }

    function extractRecipeRefIds(text) {
      if (!text || typeof text !== 'string') return [];
      const ids = [];
      let match;
      const regex = new RegExp(RECIPE_REF_TOOL_REGEX);
      while ((match = regex.exec(text)) !== null) {
        if (match?.[1]) ids.push(match[1]);
      }
      return Array.from(new Set(ids));
    }

    function extractShoppingListSelection(text) {
      if (!text || typeof text !== 'string') return { recipeIds: [], servingsByRecipeId: {} };
      const ids = [];
      const servingsByRecipeId = {};
      let match;
      const regex = new RegExp(SHOPPING_LIST_TOOL_REGEX);
      while ((match = regex.exec(text)) !== null) {
        const raw = match?.[1] || '';
        raw
          .split(',')
          .map((v) => v.trim().replace(/\s+/g, ''))
          .filter(Boolean)
          .forEach((entry) => {
            const parts = entry.split('@');
            const id = (parts[0] || '').trim();
            if (!id) return;
            ids.push(id);
            const servingsRaw = (parts[1] || '').trim();
            if (servingsRaw) {
              const parsed = Number.parseInt(servingsRaw, 10);
              if (Number.isFinite(parsed) && parsed > 0) servingsByRecipeId[id] = parsed;
            }
          });
      }
      return { recipeIds: Array.from(new Set(ids)), servingsByRecipeId };
    }

    function extractRecipeEditPayload(text) {
      if (!text || typeof text !== 'string') return { id: '', regions: [] };
      const regex = new RegExp(RECIPE_EDIT_TOOL_REGEX);
      const match = regex.exec(text);
      if (!match?.[1]) return { id: '', regions: [] };
      const regions = (match?.[2] || '')
        .split(',')
        .map((r) => r.trim())
        .filter(Boolean);
      return { id: match[1], regions };
    }

    function stripAiToolTags(text) {
      if (!text || typeof text !== 'string') return text || '';
      return text
        .replace(RECIPE_VARIANT_TOOL_REGEX, '')
        .replace(RECIPE_REF_TOOL_REGEX, '')
        .replace(SHOPPING_LIST_TOOL_REGEX, '')
        .replace(RECIPE_EDIT_TOOL_REGEX, '')
        .trim();
    }

    async function fetchRecipeSummariesByIds(ids) {
      if (!Array.isArray(ids) || ids.length === 0) return [];
      try {
        const allRes = await fetch('/api/recipes');
        if (!allRes.ok) return [];
        const allRecipes = await allRes.json();
        const byId = new Map(
          (Array.isArray(allRecipes) ? allRecipes : []).map((r) => [
            r.id,
            {
              id: r.id,
              title: r.title || 'Rezept',
              imageUrl: r.images?.[0]?.url || r.imageUrl || '',
            },
          ])
        );
        return ids
          .map((id) => byId.get(id))
          .filter(Boolean);
      } catch {
        return [];
      }
    }

    async function fetchAllRecipesCached() {
      if (Array.isArray(allRecipesCache)) return allRecipesCache;
      try {
        const res = await fetch('/api/recipes');
        if (!res.ok) return [];
        const data = await res.json();
        allRecipesCache = Array.isArray(data) ? data : [];
        allRecipesCache.forEach((r) => {
          if (r?.id && r?.title) recipeTitleCache.set(r.id, r.title);
        });
        return allRecipesCache;
      } catch {
        return [];
      }
    }

    async function resolveRecipeDisplayName(recipeId) {
      if (!recipeId) return '';
      if (recipeTitleCache.has(recipeId)) return recipeTitleCache.get(recipeId);
      const byRef = referencedRecipesList.find((r) => r.id === recipeId)?.title || '';
      if (byRef) {
        recipeTitleCache.set(recipeId, byRef);
        return byRef;
      }
      const all = await fetchAllRecipesCached();
      const found = all.find((r) => r?.id === recipeId)?.title || '';
      if (found) recipeTitleCache.set(recipeId, found);
      return found;
    }

    function setEditButtonLabel(btn, recipeId, recipeName) {
      if (!btn) return;
      const target = recipeName || `ID ${recipeId}`;
      const safeTarget = String(target).replace(/[&<>"']/g, (ch) => (
        ch === '&' ? '&amp;' :
        ch === '<' ? '&lt;' :
        ch === '>' ? '&gt;' :
        ch === '"' ? '&quot;' : '&#39;'
      ));
      btn.innerHTML = `<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg> Änderungen in "${safeTarget}" prüfen`;
    }

    function setVariantButtonLabel(btn, recipeId, recipeName) {
      if (!btn) return;
      if (!recipeId) {
        btn.innerHTML = '<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg> Neues Rezept erstellen';
        return;
      }
      const target = recipeName || `ID ${recipeId}`;
      const safeTarget = String(target).replace(/[&<>"']/g, (ch) => (
        ch === '&' ? '&amp;' :
        ch === '<' ? '&lt;' :
        ch === '>' ? '&gt;' :
        ch === '"' ? '&quot;' : '&#39;'
      ));
      btn.innerHTML = `<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4h9v9H4zM9 9h9v9H9z"/></svg> Variante für "${safeTarget}" erstellen`;
    }

    function normalizeForMatch(value) {
      return String(value || '')
        .toLowerCase()
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .replace(/[^a-z0-9\s]/g, ' ')
        .replace(/\s+/g, ' ')
        .trim();
    }

    async function inferRecipeRefsFromText(text) {
      const normalizedText = normalizeForMatch(text);
      if (!normalizedText) return [];
      const recipes = await fetchAllRecipesCached();
      const matches = [];
      recipes.forEach((rec) => {
        const title = rec?.title || '';
        const normTitle = normalizeForMatch(title);
        if (!normTitle || normTitle.length < 5) return;
        if (normalizedText.includes(normTitle)) {
          matches.push({
            id: rec.id,
            title,
            imageUrl: rec.images?.[0]?.url || rec.imageUrl || '',
            score: normTitle.length,
          });
        }
      });
      return matches
        .sort((a, b) => b.score - a.score)
        .slice(0, 4)
        .map(({ score, ...rest }) => rest);
    }

    function createRecipeReferenceCards(container, recipeRefs) {
      if (!container || !Array.isArray(recipeRefs) || recipeRefs.length === 0) return;
      const wrap = document.createElement('div');
      wrap.className = 'mt-2 w-full max-w-[85%] grid gap-2';
      recipeRefs.forEach((rec) => {
        const link = document.createElement('a');
        link.href = withDebugParam(`/rezept/${rec.id}`);
        link.className = 'flex items-center gap-3 rounded-lg border border-indigo-200 dark:border-indigo-800 bg-white dark:bg-gray-800 px-3 py-2 hover:bg-indigo-50 dark:hover:bg-indigo-900/20 transition-colors';
        link.style.maxWidth = '360px';
        link.style.minHeight = '64px';
        if (rec.imageUrl) {
          const img = document.createElement('img');
          img.src = rec.imageUrl;
          img.alt = rec.title || 'Rezeptbild';
          img.className = 'rounded object-cover flex-shrink-0';
          img.style.width = '56px';
          img.style.height = '56px';
          img.style.objectFit = 'cover';
          link.appendChild(img);
        } else {
          const placeholder = document.createElement('div');
          placeholder.className = 'rounded bg-gray-200 dark:bg-gray-700 flex-shrink-0 flex items-center justify-center text-gray-500 dark:text-gray-300 text-xs font-semibold';
          placeholder.style.width = '56px';
          placeholder.style.height = '56px';
          placeholder.textContent = 'REZEPT';
          link.appendChild(placeholder);
        }
        const text = document.createElement('span');
        text.className = 'text-sm font-medium text-gray-900 dark:text-gray-100';
        text.style.lineHeight = '1.2';
        text.textContent = rec.title || 'Rezept';
        link.appendChild(text);
        wrap.appendChild(link);
      });
      container.appendChild(wrap);
    }

    function createRecipeReferenceFallback(container, unresolvedIds) {
      if (!container || !Array.isArray(unresolvedIds) || unresolvedIds.length === 0) return;
      const hint = document.createElement('div');
      hint.className = 'mt-2 max-w-[85%] rounded-lg border border-amber-200 dark:border-amber-800 bg-amber-50 dark:bg-amber-900/20 px-3 py-2 text-xs text-amber-800 dark:text-amber-200';
      hint.textContent = `Einige Rezept-Referenzen konnten nicht aufgelöst werden: ${unresolvedIds.join(', ')}`;
      container.appendChild(hint);
    }

    function createShoppingListSuggestionButton(container, recipeIds, servingsByRecipeId) {
      if (!container || !Array.isArray(recipeIds) || recipeIds.length === 0) return;
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'mt-2 py-1 px-2 text-[11px] font-medium text-indigo-700 dark:text-indigo-300 bg-indigo-50 dark:bg-indigo-900/25 hover:bg-indigo-100 dark:hover:bg-indigo-900/40 border border-indigo-200 dark:border-indigo-800 rounded-md transition-colors inline-flex items-center gap-1';
      btn.innerHTML = '<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg> Zur Einkaufsliste hinzufügen';
      btn.addEventListener('click', async () => {
        if (!window.openShoppingListModal) {
          alert('Einkaufslisten-Modal ist nicht verfügbar.');
          return;
        }
        btn.disabled = true;
        btn.textContent = 'Wird vorbereitet...';
        try {
          // Ensure the shopping list modal is not hidden behind chat.
          closeModal();
          await window.openShoppingListModal(new Set(recipeIds), servingsByRecipeId || {});
        } finally {
          btn.disabled = false;
          btn.innerHTML = '<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg> Zur Einkaufsliste hinzufügen';
        }
      });
      container.appendChild(btn);
    }

    function createRecipeEditSuggestionButton(container, recipeId, rawAssistantContent, regions) {
      if (!container || !recipeId) return;
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'mt-2 py-1.5 px-2.5 text-xs font-medium text-indigo-700 dark:text-indigo-300 bg-indigo-50 dark:bg-indigo-900/25 hover:bg-indigo-100 dark:hover:bg-indigo-900/40 border border-indigo-200 dark:border-indigo-800 rounded-md transition-colors inline-flex items-center gap-1 leading-none';
      setEditButtonLabel(btn, recipeId, '');
      resolveRecipeDisplayName(recipeId).then((name) => {
        if (btn && !btn.disabled) setEditButtonLabel(btn, recipeId, name);
      });
      const fixIconSize = () => {
        const svg = btn.querySelector('svg');
        if (svg instanceof SVGElement) {
          svg.style.width = '14px';
          svg.style.height = '14px';
          svg.style.flexShrink = '0';
        }
      };
      fixIconSize();
      btn.addEventListener('click', async () => {
        btn.disabled = true;
        btn.textContent = 'Wird vorbereitet...';
        try {
          const primaryId = getPrimaryRecipeId();
          const recipeIds = referencedRecipesList.length > 0 ? referencedRecipesList.map((r) => r.id) : [primaryId];
          const res = await fetch('/api/ai/propose-edit', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              recipeId,
              recipeIds,
              regions: Array.isArray(regions) ? regions : [],
              editMessage: stripAiToolTags(rawAssistantContent || ''),
              ...getAISettings(),
              provider: activeChatProvider,
              model: activeChatModel,
            }),
          });
          const data = await res.json().catch(() => ({}));
          if (!res.ok) {
            alert(data.error || 'Edit-Vorschlag konnte nicht vorbereitet werden.');
            return;
          }
          if (data.preview === true && data.token) {
            window.location.href = withDebugParam(`/rezept/${recipeId}?edit=true&aiDraft=1&aiEditToken=${encodeURIComponent(data.token)}`);
            return;
          }
          alert('Edit-Vorschlag konnte nicht vorbereitet werden.');
        } catch (e) {
          console.error('AI edit proposal failed', e);
          alert('Fehler beim Vorbereiten der Änderungen.');
        } finally {
          btn.disabled = false;
          setEditButtonLabel(btn, recipeId, recipeTitleCache.get(recipeId) || '');
          fixIconSize();
        }
      });
      container.appendChild(btn);
    }

    function appendAssistantToolUi(container, rawContent) {
      if (!container) return;
      const recipeRefIds = extractRecipeRefIds(rawContent || '');
      const shoppingListSelection = extractShoppingListSelection(rawContent || '');
      const recipeEdit = extractRecipeEditPayload(rawContent || '');

      if (recipeRefIds.length > 0) {
        fetchRecipeSummariesByIds(recipeRefIds).then((refs) => {
          createRecipeReferenceCards(container, refs);
          const resolvedIds = new Set((refs || []).map((r) => r.id));
          const unresolved = recipeRefIds.filter((id) => !resolvedIds.has(id));
          createRecipeReferenceFallback(container, unresolved);
        });
      } else if (isAllRecipesContext()) {
        inferRecipeRefsFromText(rawContent || '').then((refs) => {
          if (refs.length > 0) createRecipeReferenceCards(container, refs);
        });
      }

      if (shoppingListSelection.recipeIds.length > 0) {
        createShoppingListSuggestionButton(
          container,
          shoppingListSelection.recipeIds,
          shoppingListSelection.servingsByRecipeId
        );
      }
      if (recipeEdit.id) {
        createRecipeEditSuggestionButton(container, recipeEdit.id, rawContent || '', recipeEdit.regions);
      }
    }

    function renderMarkdown(target, text) {
      const markedGlobal = getMarked();
      if (text && markedGlobal && typeof markedGlobal.parse === 'function') {
        target.innerHTML = markedGlobal.parse(text, { breaks: true });
        target.querySelectorAll('a').forEach((a) => {
          a.setAttribute('target', '_blank');
          a.setAttribute('rel', 'noopener noreferrer');
        });
      } else {
        target.textContent = text || '';
      }
    }

    function renderAssistantContent(bubble, thinkingHost, content) {
      const cleaned = stripAiToolTags(content || '');
      const split = splitThinkingContent(cleaned);
      renderMarkdown(bubble, split.visible);
      if (!thinkingHost) return;
      thinkingHost.innerHTML = '';
      if (!split.thinking) return;
      const details = document.createElement('details');
      details.className = 'mt-1 max-w-[85%] text-xs text-gray-600 dark:text-gray-300';
      const summary = document.createElement('summary');
      summary.className = 'cursor-pointer select-none text-[11px] text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200';
      summary.textContent = 'Thinking anzeigen';
      const body = document.createElement('div');
      body.className = 'mt-1 px-3 py-2 rounded-lg bg-gray-100 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 prose prose-xs dark:prose-invert max-w-none';
      renderMarkdown(body, split.thinking);
      details.appendChild(summary);
      details.appendChild(body);
      thinkingHost.appendChild(details);
    }

    function appendRegenerateButton(wrap, messageIndex) {
      if (!wrap || typeof messageIndex !== 'number') return;
      const regenBtn = document.createElement('button');
      regenBtn.type = 'button';
      regenBtn.className = 'mt-1 text-[11px] text-gray-500 dark:text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400 underline-offset-2 hover:underline self-start';
      regenBtn.textContent = 'Antwort neu generieren';
      regenBtn.addEventListener('click', () => regenerateMessage(messageIndex));
      wrap.appendChild(regenBtn);
    }

    function appendVariantButtonIfNeeded(wrap, bubble, content, messageIndex) {
      const variantPayload = extractVariantPayload(content || '');
      if (!variantPayload.hasVariant) return;
      const displayContent = stripVariantKeyword(content);
      renderAssistantContent(bubble, null, displayContent);
      wrap.setAttribute('data-message-index', String(messageIndex));
      wrap.classList.add('flex-col', 'items-start');
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.setAttribute('data-ai-variant-btn', '1');
      if (variantPayload.recipeId) btn.setAttribute('data-ai-variant-recipe-id', variantPayload.recipeId);
      btn.className = 'mt-1 py-1 px-2 text-[11px] font-medium text-indigo-700 dark:text-indigo-300 bg-indigo-50 dark:bg-indigo-900/25 hover:bg-indigo-100 dark:hover:bg-indigo-900/40 border border-indigo-200 dark:border-indigo-800 rounded-md transition-colors inline-flex items-center gap-1';
      setVariantButtonLabel(btn, variantPayload.recipeId || '', '');
      if (variantPayload.recipeId) {
        resolveRecipeDisplayName(variantPayload.recipeId).then((name) => {
          if (btn && !btn.disabled) setVariantButtonLabel(btn, variantPayload.recipeId, name);
        });
      }
      btn.addEventListener('click', () => createVariantFromMessage(messageIndex));
      wrap.appendChild(btn);
    }

    function renderMessage(role, content, options) {
      const useMarkdown = options?.markdown !== false;
      const messageIndex = options?.messageIndex;
      const variantPayload = role === 'assistant' ? extractVariantPayload(content || '') : { hasVariant: false, recipeId: '' };
      const isVariantMessage = role === 'assistant' && variantPayload.hasVariant;
      const recipeRefIds = role === 'assistant' ? extractRecipeRefIds(content || '') : [];
      const withoutToolTags = role === 'assistant' ? stripAiToolTags(content || '') : (content || '');
      const displayContent = isVariantMessage ? stripVariantKeyword(withoutToolTags) : withoutToolTags;

      const div = document.createElement('div');
      div.className = `flex flex-col ${role === 'user' ? 'items-end' : 'items-start'} ${role === 'user' ? 'justify-end' : 'justify-start'}`;
      if (isVariantMessage && typeof messageIndex === 'number') {
        div.setAttribute('data-message-index', String(messageIndex));
      }
      const bubble = document.createElement('div');
      bubble.className = role === 'user'
        ? 'max-w-[85%] px-4 py-2 rounded-2xl rounded-br-md bg-indigo-600 text-white text-sm ai-msg-bubble'
        : 'max-w-[85%] px-4 py-2 rounded-2xl rounded-bl-md bg-gray-200 dark:bg-gray-700 text-gray-900 dark:text-gray-100 text-sm ai-msg-bubble prose prose-sm dark:prose-invert max-w-none';
      const thinkingHost = role === 'assistant' ? document.createElement('div') : null;
      if (role === 'assistant' && useMarkdown) {
        renderAssistantContent(bubble, thinkingHost, displayContent || '');
      } else {
        bubble.textContent = displayContent || '';
      }
      div.appendChild(bubble);
      if (thinkingHost) div.appendChild(thinkingHost);
      if (isVariantMessage && typeof messageIndex === 'number') {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.setAttribute('data-ai-variant-btn', '1');
        if (variantPayload.recipeId) btn.setAttribute('data-ai-variant-recipe-id', variantPayload.recipeId);
        btn.className = 'mt-1 py-1 px-2 text-[11px] font-medium text-indigo-700 dark:text-indigo-300 bg-indigo-50 dark:bg-indigo-900/25 hover:bg-indigo-100 dark:hover:bg-indigo-900/40 border border-indigo-200 dark:border-indigo-800 rounded-md transition-colors inline-flex items-center gap-1';
        setVariantButtonLabel(btn, variantPayload.recipeId || '', '');
        if (variantPayload.recipeId) {
          resolveRecipeDisplayName(variantPayload.recipeId).then((name) => {
            if (btn && !btn.disabled) setVariantButtonLabel(btn, variantPayload.recipeId, name);
          });
        }
        btn.addEventListener('click', () => createVariantFromMessage(messageIndex));
        div.appendChild(btn);
      }
      if (role === 'assistant' && typeof messageIndex === 'number') {
        const regenBtn = document.createElement('button');
        regenBtn.type = 'button';
        regenBtn.className = 'mt-1 text-[11px] text-gray-500 dark:text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400 underline-offset-2 hover:underline self-start';
        regenBtn.textContent = 'Antwort neu generieren';
        regenBtn.addEventListener('click', () => regenerateMessage(messageIndex));
        div.appendChild(regenBtn);
      }
      if (role === 'assistant') {
        appendAssistantToolUi(div, content || '');
      }
      return div;
    }

    function renderMessages() {
      if (!messagesContainer || !placeholder) return;
      placeholder.classList.toggle('hidden', messages.length > 0);
      const existing = messagesContainer.querySelectorAll('[data-ai-msg]');
      existing.forEach((el) => el.remove());
      messages.forEach((m, i) => {
        const el = renderMessage(m.role, m.content, { messageIndex: i });
        el.setAttribute('data-ai-msg', '');
        messagesContainer.appendChild(el);
      });
      messagesContainer.scrollTop = messagesContainer.scrollHeight;
    }

    async function sendMessage(options = {}) {
      const text = typeof options.textOverride === 'string'
        ? options.textOverride.trim()
        : (input && input.value) ? input.value.trim() : '';
      if (!text || !sendBtn) return;

      if (isGenerating) return;
      isGenerating = true;
      currentAbortController = new AbortController();
      sendBtn.disabled = false;
      const sendLabel = sendBtn.querySelector('.recipe-ai-chat-send-label');
      if (sendLabel) sendLabel.textContent = 'Abbrechen';
      sendBtn.title = 'Generierung abbrechen';
      const baseHistory = Array.isArray(options.historyOverride)
        ? normalizeChatMessages(options.historyOverride)
        : normalizeChatMessages(messages);
      const activeTab = getActiveTab();
      if (activeTab) {
        activeTab.provider = activeChatProvider;
        activeTab.model = activeChatModel;
      }
      const userEl = renderMessage('user', text);
      userEl.setAttribute('data-ai-msg', '');
      if (placeholder) placeholder.classList.add('hidden');
      messagesContainer.appendChild(userEl);
      messagesContainer.scrollTop = messagesContainer.scrollHeight;
      if (!options.textOverride && input) input.value = '';

      const assistantWrap = document.createElement('div');
      assistantWrap.className = 'flex flex-col items-start justify-start';
      assistantWrap.setAttribute('data-ai-msg', '');
      const bubble = document.createElement('div');
      bubble.className = 'max-w-[85%] px-4 py-2 rounded-2xl rounded-bl-md bg-gray-200 dark:bg-gray-700 text-gray-900 dark:text-gray-100 text-sm ai-msg-bubble prose prose-sm dark:prose-invert max-w-none';
      bubble.textContent = '';
      const thinkingHost = document.createElement('div');
      assistantWrap.appendChild(bubble);
      assistantWrap.appendChild(thinkingHost);
      messagesContainer.appendChild(assistantWrap);
      messagesContainer.scrollTop = messagesContainer.scrollHeight;

      let accumulated = '';
      let streamError = null;
      let donePushed = false;
      let usageMeta = null;
      let cacheMeta = null;

      try {
        const primaryId = getPrimaryRecipeId();
        const recipeIds = referencedRecipesList.length > 0 ? referencedRecipesList.map((r) => r.id) : [recipeId];
        const res = await fetch('/api/ai/chat', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            recipeId: primaryId,
            recipeIds,
            chatId: activeChatTabId,
            history: baseHistory,
            message: text,
            ...getAISettings(),
            provider: activeChatProvider,
            model: activeChatModel,
          }),
          signal: currentAbortController.signal
        });
        if (!res.ok || !res.body) {
          const data = await res.json().catch(() => ({}));
          throw new Error(data.error || 'Request failed');
        }
        const reader = res.body.getReader();
        const decoder = new TextDecoder();
        let buffer = '';
        while (true) {
          const { done, value } = await reader.read();
          if (done) break;
          buffer += decoder.decode(value, { stream: true });
          const lines = buffer.split('\n');
          buffer = lines.pop() ?? '';
          for (const line of lines) {
            const trimmed = line.trim();
            if (!trimmed) continue;
            try {
              const data = JSON.parse(trimmed);
              if (DEBUG_ENABLED) {
                console.log('[AI DEBUG stream line]', trimmed);
              }
              if (data.error) {
                streamError = data.error;
                break;
              }
              if (typeof data.delta === 'string') {
                accumulated += data.delta;
                renderAssistantContent(bubble, thinkingHost, accumulated);
                messagesContainer.scrollTop = messagesContainer.scrollHeight;
              }
              if (data.cache && typeof data.cache === 'object') cacheMeta = data.cache;
              if (data.usage && typeof data.usage === 'object') usageMeta = data.usage;
              if (data.done && typeof data.fullMessage === 'string' && !donePushed) {
                accumulated = data.fullMessage;
                renderAssistantContent(bubble, thinkingHost, accumulated);
                messages = [...baseHistory, { role: 'user', content: text }, { role: 'assistant', content: accumulated }];
                touchActiveTab();
                donePushed = true;
                appendAssistantToolUi(assistantWrap, accumulated);
                appendVariantButtonIfNeeded(assistantWrap, bubble, accumulated, messages.length - 1);
                appendRegenerateButton(assistantWrap, messages.length - 1);
              }
            } catch (_e) { /* skip malformed line */ }
          }
          if (streamError) break;
        }
        for (const line of buffer.split('\n').map((l) => l.trim()).filter(Boolean)) {
          try {
            const data = JSON.parse(line);
            if (data.error) { streamError = data.error; break; }
            if (data.cache && typeof data.cache === 'object') cacheMeta = data.cache;
            if (data.usage && typeof data.usage === 'object') usageMeta = data.usage;
            if (data.done && typeof data.fullMessage === 'string' && !donePushed) {
              accumulated = data.fullMessage;
              renderAssistantContent(bubble, thinkingHost, accumulated);
              messages = [...baseHistory, { role: 'user', content: text }, { role: 'assistant', content: accumulated }];
              touchActiveTab();
              donePushed = true;
              appendAssistantToolUi(assistantWrap, accumulated);
              appendVariantButtonIfNeeded(assistantWrap, bubble, accumulated, messages.length - 1);
              appendRegenerateButton(assistantWrap, messages.length - 1);
            }
          } catch (_e) {}
        }
        if (streamError) {
          bubble.textContent = 'Fehler: ' + streamError;
          thinkingHost.innerHTML = '';
          messages = [...baseHistory, { role: 'user', content: text }, { role: 'assistant', content: 'Fehler: ' + streamError }];
          touchActiveTab();
          appendRegenerateButton(assistantWrap, messages.length - 1);
        } else if (!donePushed) {
          if (accumulated) {
            renderAssistantContent(bubble, thinkingHost, accumulated);
            messages = [...baseHistory, { role: 'user', content: text }, { role: 'assistant', content: accumulated }];
            touchActiveTab();
            appendAssistantToolUi(assistantWrap, accumulated);
            appendVariantButtonIfNeeded(assistantWrap, bubble, accumulated, messages.length - 1);
            appendRegenerateButton(assistantWrap, messages.length - 1);
          } else {
            bubble.textContent = 'Keine Antwort erhalten.';
            messages = [...baseHistory, { role: 'user', content: text }, { role: 'assistant', content: 'Keine Antwort erhalten.' }];
            touchActiveTab();
            appendRegenerateButton(assistantWrap, messages.length - 1);
          }
        }
        if (cacheMeta && usageMeta && typeof usageMeta.cachedTokens === 'number') {
          const cached = usageMeta.cachedTokens || 0;
          const write = typeof usageMeta.cacheWriteTokens === 'number' ? usageMeta.cacheWriteTokens : 0;
          const discount = typeof usageMeta.cacheDiscount === 'number' ? usageMeta.cacheDiscount : null;
          const discountText = discount != null ? `, Rabatt: ${discount.toFixed(6)}` : '';
          setCacheImpact(`Cache-Metrik: read=${cached} / write=${write}${discountText}`);
        } else if (options.regenerate) {
          setCacheImpact('Antwort neu generiert: Folgeanfragen nutzen nun den neuen Verlauf als Cache-Basis.');
        } else {
          setCacheImpact('');
        }
        if (DEBUG_ENABLED) {
          console.log('[AI DEBUG full assistant raw]', accumulated);
        }
        messagesContainer.scrollTop = messagesContainer.scrollHeight;
      } catch (e) {
        const isAbort = e && typeof e === 'object' && e.name === 'AbortError';
        if (isAbort) {
          const finalContent = accumulated || 'Generierung abgebrochen.';
          if (accumulated) {
            renderAssistantContent(bubble, thinkingHost, accumulated);
          } else {
            bubble.textContent = finalContent;
            thinkingHost.innerHTML = '';
          }
          messages = [...baseHistory, { role: 'user', content: text }, { role: 'assistant', content: finalContent }];
          touchActiveTab();
          appendAssistantToolUi(assistantWrap, finalContent);
          appendVariantButtonIfNeeded(assistantWrap, bubble, finalContent, messages.length - 1);
          appendRegenerateButton(assistantWrap, messages.length - 1);
        } else {
          bubble.textContent = e instanceof Error ? e.message : 'Netzwerkfehler. Bitte erneut versuchen.';
          thinkingHost.innerHTML = '';
          messages = [...baseHistory, { role: 'user', content: text }, { role: 'assistant', content: bubble.textContent }];
          touchActiveTab();
          appendRegenerateButton(assistantWrap, messages.length - 1);
        }
        messagesContainer.scrollTop = messagesContainer.scrollHeight;
      } finally {
        isGenerating = false;
        currentAbortController = null;
        sendBtn.disabled = false;
        const sendLabel = sendBtn.querySelector('.recipe-ai-chat-send-label');
        if (sendLabel) sendLabel.textContent = 'Senden';
        sendBtn.title = 'Senden';
        input.focus();
      }
    }

    async function deleteChat() {
      if (!confirm('Chat-Verlauf wirklich löschen? Dies kann nicht rückgängig gemacht werden.')) return;
      messages = [];
      const idx = chatTabs.findIndex((t) => t.id === activeChatTabId);
      if (idx >= 0) {
        chatTabs[idx].title = 'Neuer Chat';
        chatTabs[idx].aiTitleGenerated = false;
        chatTabs[idx].messages = [];
      }
      touchActiveTab();
      renderMessages();
      if (placeholder) placeholder.classList.remove('hidden');
      setCacheImpact('Chat gelöscht: Cache wird für diesen Tab neu aufgebaut.');
      syncHeaderModelChooser();
    }

    async function createVariantFromMessage(messageIndex) {
      const content = messages[messageIndex]?.content;
      if (!content) return;
      const variantMessage = stripVariantKeyword(content);
      if (!variantMessage.trim()) return;

      const btn = document.querySelector(`[data-message-index="${messageIndex}"] [data-ai-variant-btn="1"]`);
      const targetRecipeId = btn ? btn.getAttribute('data-ai-variant-recipe-id') || '' : '';
      if (btn) {
        btn.disabled = true;
        btn.textContent = 'Wird vorbereitet…';
      }
      try {
        const primaryId = getPrimaryRecipeId();
        const recipeIds = referencedRecipesList.length > 0 ? referencedRecipesList.map((r) => r.id) : [primaryId];
        const res = await fetch('/api/ai/propose-variant', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            recipeId: primaryId,
            targetRecipeId,
            recipeIds,
            variantMessage,
            preview: true,
            ...getAISettings(),
            provider: activeChatProvider,
            model: activeChatModel,
          })
        });
        const data = await res.json();
        if (!res.ok) {
          alert(data.error || 'Variante konnte nicht vorbereitet werden.');
          return;
        }
        if (data.preview === true && data.mode === 'variant' && data.token && data.parentRecipeId) {
          window.location.href = withDebugParam(`/rezept/${data.parentRecipeId}/variante-neu?draft=${encodeURIComponent(data.token)}`);
          return;
        }
        if (data.preview === true && data.mode === 'new_recipe' && data.recipeId) {
          window.location.href = withDebugParam(`/rezept/${data.recipeId}?edit=true`);
          return;
        }
        if (window.showSuccess) {
          window.showSuccess('Variante wurde erstellt.');
        } else {
          alert('Variante wurde erstellt.');
        }
        if (data.id) window.location.href = withDebugParam(`/rezept/${data.id}`);
      } catch (e) {
        console.error('Create variant failed', e);
        alert('Fehler beim Erstellen der Variante.');
      } finally {
        if (btn) {
          btn.disabled = false;
          setVariantButtonLabel(btn, targetRecipeId, recipeTitleCache.get(targetRecipeId) || '');
        }
      }
    }

    function setChatModalScrollLock(locked) {
      document.body.classList.toggle('overflow-hidden', locked);
      document.documentElement.classList.toggle('overflow-hidden', locked);
    }

    async function openModal() {
      if (!modal) return;
      const fab = document.getElementById('recipe-ai-chat-fab');
      if (fab) fab.classList.add('hidden');
      referencedRecipesList = Array.isArray(initialReferencedRecipes)
        ? initialReferencedRecipes.map((r) => ({ id: r.id, title: r.title || '', imageUrl: r.imageUrl }))
        : [];
      renderReferencedBar();
      updateChatViewportHeightVar();
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      setChatModalScrollLock(true);
      await syncHeaderModelChooser();
      initChatTabs();
      setTimeout(() => input && input.focus(), 100);
    }

    function closeModal() {
      if (!modal) return;
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      setChatModalScrollLock(false);
      const fab = document.getElementById('recipe-ai-chat-fab');
      if (fab) fab.classList.remove('hidden');
      document.dispatchEvent(new CustomEvent('recipe-ai-chat-closed'));
    }

    closeBtn && closeBtn.addEventListener('click', closeModal);
    deleteBtn && deleteBtn.addEventListener('click', deleteChat);
    newChatTabBtn && newChatTabBtn.addEventListener('click', createChatTab);
    aiProviderSelect && aiProviderSelect.addEventListener('change', async () => {
      const activeTab = getActiveTab();
      if (isTabModelLocked(activeTab)) {
        setCacheImpact('Modellwechsel gesperrt: Dieser Chat hat bereits Verlauf und behält sein Modell für stabile Cache-Hits.');
        syncHeaderModelChooser();
        return;
      }
      const settings = getDefaultAIConfig();
      const provider = aiProviderSelect.value === 'openrouter' ? 'openrouter' : 'ollama';
      const memory = getChatModelMemory();
      const preferredModel = provider === settings.provider ? settings.model : (memory[provider] || '');
      const model = await loadModelsForHeader(provider, settings.openRouterApiKey, preferredModel);
      activeChatProvider = provider;
      activeChatModel = model || '';
      if (activeTab) {
        activeTab.provider = activeChatProvider;
        activeTab.model = activeChatModel;
      }
      if (provider !== settings.provider && activeChatModel) {
        setChatModelMemory({ ...memory, [provider]: activeChatModel });
      }
      setCacheImpact('Modell geändert: Der nächste Prompt startet einen neuen Cache-Pfad.');
      updateCacheHint();
      persistChatTabs();
    });
    aiModelSelect && aiModelSelect.addEventListener('change', () => {
      const activeTab = getActiveTab();
      if (isTabModelLocked(activeTab)) {
        setCacheImpact('Modellwechsel gesperrt: Dieser Chat hat bereits Verlauf und behält sein Modell für stabile Cache-Hits.');
        syncHeaderModelChooser();
        return;
      }
      const settings = getDefaultAIConfig();
      const selectedModel = aiModelSelect.value || '';
      activeChatModel = selectedModel;
      if (activeTab) {
        activeTab.provider = activeChatProvider;
        activeTab.model = activeChatModel;
      }
      if (activeChatProvider !== settings.provider && selectedModel) {
        const memory = getChatModelMemory();
        setChatModelMemory({ ...memory, [activeChatProvider]: selectedModel });
      }
      setCacheImpact('Modell geändert: Der nächste Prompt startet einen neuen Cache-Pfad.');
      updateCacheHint();
      persistChatTabs();
    });
    aiModelRefreshBtn && aiModelRefreshBtn.addEventListener('click', async () => {
      const settings = getDefaultAIConfig();
      const provider = aiProviderSelect && aiProviderSelect.value === 'openrouter' ? 'openrouter' : 'ollama';
      const selectedModel = await loadModelsForHeader(
        provider,
        settings.openRouterApiKey,
        aiModelSelect ? aiModelSelect.value : activeChatModel
      );
      activeChatProvider = provider;
      activeChatModel = selectedModel || '';
      const activeTab = getActiveTab();
      if (activeTab && !isTabModelLocked(activeTab)) {
        activeTab.provider = activeChatProvider;
        activeTab.model = activeChatModel;
      }
      if (provider !== settings.provider && activeChatModel) {
        const memory = getChatModelMemory();
        setChatModelMemory({ ...memory, [provider]: activeChatModel });
      }
      updateCacheHint();
    });
    document.addEventListener('ai-settings-updated', () => {
      if (!modal || modal.classList.contains('hidden')) return;
      syncHeaderModelChooser();
    });
    sendBtn && sendBtn.addEventListener('click', () => {
      if (isGenerating && currentAbortController) {
        currentAbortController.abort();
        return;
      }
      sendMessage();
    });

    input && input.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        sendMessage();
      }
    });

    modal && modal.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal && !modal.classList.contains('hidden')) closeModal();
    });

    updateChatViewportHeightVar();
    window.addEventListener('resize', updateChatViewportHeightVar);
    window.addEventListener('orientationchange', () => {
      setTimeout(updateChatViewportHeightVar, 60);
    });
    if (window.visualViewport) {
      window.visualViewport.addEventListener('resize', updateChatViewportHeightVar);
      window.visualViewport.addEventListener('scroll', updateChatViewportHeightVar);
    }

    window.openRecipeAIChatModal = openModal;
  })();
</script>

<style>
  #recipe-ai-chat-modal,
  #recipe-ai-chat-picker-modal {
    isolation: isolate;
    transform: translateZ(0);
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    overscroll-behavior: contain;
  }

  #recipe-ai-chat-modal > div:last-child,
  #recipe-ai-chat-picker-modal > div:last-child {
    position: relative;
    z-index: 1;
    transform: translateZ(0);
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    will-change: transform, opacity;
  }

  .recipe-ai-chat-overlay {
    transform: translateZ(0);
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }

  .recipe-ai-chat-panel {
    height: var(--recipe-ai-chat-vh, 100dvh);
    max-height: var(--recipe-ai-chat-vh, 100dvh);
  }

  .recipe-ai-chat-input-row {
    padding-bottom: calc(1rem + env(safe-area-inset-bottom, 0px));
  }

  @media (max-width: 768px), (pointer: coarse) {
    #recipe-ai-chat-modal {
      align-items: stretch;
    }

    .recipe-ai-chat-panel {
      width: 100vw;
      height: var(--recipe-ai-chat-vh, 100dvh);
      max-height: var(--recipe-ai-chat-vh, 100dvh);
      border-radius: 0;
    }

    .recipe-ai-chat-overlay {
      backdrop-filter: none !important;
      -webkit-backdrop-filter: none !important;
    }
  }
</style>
