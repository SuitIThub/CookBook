---
import type { Recipe, IngredientGroup } from '../../../types/recipe';
import IngredientNode from './IngredientNode.astro';
import {
  getAlternativeGroups,
  getOptionToGroupMap,
  getDefaultSelection,
  isVisibleWhenSatisfied,
} from '../../../lib/alternatives';

interface Props {
  recipe: Recipe;
}

const { recipe } = Astro.props;

// Recursive function to check if there are any ingredients (including nested)
function hasAnyIngredientsRecursive(groups: IngredientGroup[]): boolean {
  return groups.some(group => {
    if (!group?.ingredients || group.ingredients.length === 0) return false;
    return group.ingredients.some(item => {
      if ('name' in item) {
        return true; // It's an ingredient
      } else if ('ingredients' in item) {
        return hasAnyIngredientsRecursive([item as IngredientGroup]); // It's a nested group
      }
      return false;
    });
  });
}

// Safety check: ensure ingredientGroups exists and handle empty arrays
const ingredientGroups = recipe?.ingredientGroups || [];
const hasAnyIngredients = hasAnyIngredientsRecursive(ingredientGroups);

// Alternatives context
const groups = getAlternativeGroups(recipe);
const optionToGroup = getOptionToGroupMap(recipe);
const selection = getDefaultSelection(recipe);
const hasAlternatives = groups.size > 0;
---

<div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 transition-colors duration-200">
  <div class="p-6">
    <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4 flex items-center">
      <svg class="w-6 h-6 mr-2 text-orange-500" fill="currentColor" viewBox="0 0 20 20">
        <path d="M3 4a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V4zM3 10a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H4a1 1 0 01-1-1v-6zM14 9a1 1 0 00-1 1v6a1 1 0 001 1h2a1 1 0 001-1v-6a1 1 0 00-1-1h-2z"/>
      </svg>
      Zutaten
    </h2>

    {!hasAnyIngredients ? (
      <div class="text-gray-500 dark:text-gray-400 italic">
        Keine Zutaten gefunden - bitte manuell hinzufügen.
      </div>
    ) : (
      <div
        class="space-y-4"
        id="ingredients-display"
        data-has-alternatives={hasAlternatives ? 'true' : 'false'}
        data-default-selection={JSON.stringify(selection)}
        data-recipe-id={recipe.id}
      >
        {/* First show ungrouped ingredients */}
        {ingredientGroups.filter(group => group && !group.title).map((group) => (
          <ul
            class:list={["space-y-2 recipe-ing-node", { hidden: !isVisibleWhenSatisfied(group.visibleWhen, selection, optionToGroup) }]}
            data-node-type="group"
            data-group-id={group.id}
            data-visible-when={group.visibleWhen && group.visibleWhen.optionIds && group.visibleWhen.optionIds.length > 0 ? JSON.stringify(group.visibleWhen.optionIds) : undefined}
          >
            {(group.ingredients || []).map((item) => (
              <IngredientNode item={item} selection={selection} optionToGroup={optionToGroup} groups={groups} depth={0} />
            ))}
          </ul>
        ))}

        {/* Then show grouped ingredients */}
        {ingredientGroups.filter(group => group && group.title).map((group) => (
          <div
            class:list={["recipe-ing-node", { hidden: !isVisibleWhenSatisfied(group.visibleWhen, selection, optionToGroup) }]}
            data-node-type="group"
            data-group-id={group.id}
            data-visible-when={group.visibleWhen && group.visibleWhen.optionIds && group.visibleWhen.optionIds.length > 0 ? JSON.stringify(group.visibleWhen.optionIds) : undefined}
          >
            <h3 class="font-semibold text-gray-800 dark:text-gray-200 mb-2 border-b border-gray-200 dark:border-gray-600 pb-1">
              {group.title}
            </h3>
            <ul class="space-y-2">
              {(group.ingredients || []).map((item) => (
                <IngredientNode item={item} selection={selection} optionToGroup={optionToGroup} groups={groups} depth={0} />
              ))}
            </ul>
          </div>
        ))}
      </div>
    )}
  </div>
</div>

<script>
  // Coordinates alternative selection + dependency visibility across the recipe view.
  (function () {
    const container = document.getElementById('ingredients-display');
    if (!container) return;

    // optionId -> groupId, built from the rendered alternative selects/rows.
    const optionToGroup = new Map<string, string>();
    document.querySelectorAll<HTMLElement>('[data-alternative-group][data-option-id]').forEach((el) => {
      const groupId = el.getAttribute('data-alternative-group');
      const optionId = el.getAttribute('data-option-id');
      if (groupId && optionId) optionToGroup.set(optionId, groupId);
    });

    // Initialize selection from server-provided default.
    let selection: Record<string, string> = {};
    try {
      selection = JSON.parse(container.getAttribute('data-default-selection') || '{}');
    } catch (e) {
      selection = {};
    }

    function visibleWhenSatisfied(optionIds: string[] | null): boolean {
      if (!optionIds || optionIds.length === 0) return true;
      for (const oid of optionIds) {
        const gid = optionToGroup.get(oid);
        if (!gid) return true; // referenced option no longer exists -> dependency void
        if (selection[gid] === oid) return true;
      }
      return false;
    }

    function parseVisibleWhen(el: Element): string[] | null {
      const raw = el.getAttribute('data-visible-when');
      if (!raw) return null;
      try {
        const arr = JSON.parse(raw);
        return Array.isArray(arr) ? arr : null;
      } catch (e) {
        return null;
      }
    }

    function applyVisibility() {
      // Alternative ingredient rows: only the selected option of each group is shown.
      document.querySelectorAll<HTMLElement>('[data-alternative-group][data-option-id]').forEach((el) => {
        const groupId = el.getAttribute('data-alternative-group')!;
        const optionId = el.getAttribute('data-option-id')!;
        const isSelectedOption = selection[groupId] === optionId;
        const dependencyOk = visibleWhenSatisfied(parseVisibleWhen(el));
        el.classList.toggle('hidden', !(isSelectedOption && dependencyOk));
      });

      // Plain dependency-bound nodes (no alternative membership): ingredients, groups, steps.
      document.querySelectorAll<HTMLElement>('[data-visible-when]').forEach((el) => {
        if (el.hasAttribute('data-alternative-group')) return; // handled above
        const dependencyOk = visibleWhenSatisfied(parseVisibleWhen(el));
        el.classList.toggle('hidden', !dependencyOk);
      });

      // Keep all alternative selects in sync with the current selection.
      document.querySelectorAll<HTMLSelectElement>('select.alternative-select').forEach((sel) => {
        const groupId = sel.getAttribute('data-alternative-group');
        if (groupId && selection[groupId] != null) sel.value = selection[groupId];
      });
    }

    function onSelectChange(e: Event) {
      const sel = e.target as HTMLSelectElement;
      if (!sel.classList.contains('alternative-select')) return;
      const groupId = sel.getAttribute('data-alternative-group');
      if (!groupId) return;
      const optionId = sel.value;
      selection[groupId] = optionId;
      applyVisibility();
      document.dispatchEvent(
        new CustomEvent('alternative-selection-changed', {
          detail: { groupId, optionId, selection: { ...selection } },
        }),
      );
    }

    document.addEventListener('change', onSelectChange);

    // Expose current selection for other scripts (e.g. persistence in the page).
    (window as any).getAlternativeSelection = () => ({ ...selection });

    // Initial pass (mostly a no-op since server already rendered defaults).
    applyVisibility();
  })();
</script>
